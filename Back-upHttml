<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>for you ♡</title>

<style>
body{
  margin:0;
  height:100vh;
  background:#f7efe9;
  font-family:sans-serif;
  overflow:hidden;
}

/* SCREEN */
.screen{
  display:none;
  height:100vh;
  justify-content:center;
  align-items:center;
}

#giftScreen{display:flex;}

/* GIFT */
.gift{
  width:160px;
  height:160px;
  background:#ffb6c1;
  border-radius:20px;
  display:flex;
  justify-content:center;
  align-items:center;
  font-size:60px;
  cursor:pointer;
}

/* PASSWORD */
.box{
  width:280px;
  padding:25px;
  background:white;
  border-radius:16px;
  text-align:center;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
}

input{
  width:100%;
  padding:12px;
  margin-top:10px;
  border-radius:10px;
  border:1px solid #ddd;
}

button{
  width:100%;
  margin-top:10px;
  padding:12px;
  border:none;
  border-radius:10px;
  background:#c9a38b;
  color:white;
}

/* ENVELOPE */
.wrapper{
  width:320px;
  height:240px;
  position:relative;
}

.envelope{
  width:100%;
  height:180px;
  background:white;
  border-radius:12px;
  position:absolute;
  bottom:0;
  cursor:pointer;
  z-index:10;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
}

.envelope::before{
  content:"";
  position:absolute;
  inset:0;
  background:#f1e2d8;
  clip-path:polygon(0 0,50% 55%,100% 0,100% 100%,0 100%);
}

/* LETTER */
.letter{
  position:absolute;
  left:50%;
  bottom:10px;
  transform:translateX(-50%) scaleY(0);
  transform-origin:bottom;
  opacity:0;
  transition:0.6s ease;
  z-index:20;
}

.letter.show{
  transform:translateX(-50%) translateY(-40px) scaleY(1);
  opacity:1;
}

.letter img{
  width:340px;
  border-radius:12px;
  box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

/* MODAL */
.modal{
  display:none;
  position:fixed;
  top:0;
  left:0;
  width:100%;
  height:100%;
  background:rgba(0,0,0,0.4);
  justify-content:center;
  align-items:center;
  z-index:999;
}

.modalBox{
  background:white;
  padding:20px;
  border-radius:12px;
  width:250px;
  text-align:center;
}

.modalBox button{
  margin:5px;
  padding:8px 12px;
  border:none;
  border-radius:8px;
  cursor:pointer;
}

.yes{
  background:#c9a38b;
  color:white;
  transition:0.3s ease;
}

.no{
  background:#eee;
  position:relative;
  transition:0.2s ease;
}

#noText{
  margin-top:10px;
  font-size:13px;
  color:#444;
}

</style>
</head>

<body>

<!-- 🎁 GIFT -->
<div class="screen" id="giftScreen">
  <div onclick="toPW()">
    <div class="gift">🎁</div>
  </div>
</div>

<!-- 🔒 PASSWORD -->
<div class="screen" id="pwScreen">
  <div class="box">
    <p>enter password</p>
    <input id="pw" type="password">
    <button onclick="check()">open</button>
  </div>
</div>

<!-- 💌 ENVELOPE -->
<div class="screen" id="envScreen">
  <div class="wrapper">

    <div class="envelope" onclick="openConfirm()"></div>

    <div class="letter" id="letter">
      <img src="https://files.catbox.moe/5jqk3h.png">
    </div>

  </div>
</div>

<!-- ❓ MODAL -->
<div class="modal" id="modal">
  <div class="modalBox">
    <p>Do you want to open the letter?</p>

    <button class="yes" onclick="yesOpen()">Yes</button>
    <button class="no" onclick="noOpen()">No</button>

    <p id="noText"></p>
  </div>
</div>

<script>

/* FLOW */
function toPW(){
  document.getElementById("giftScreen").style.display="none";
  document.getElementById("pwScreen").style.display="flex";
}

function check(){
  let pw=document.getElementById("pw").value;

  if(pw.trim().toLowerCase()==="zaki"){
    document.getElementById("pwScreen").style.display="none";
    document.getElementById("envScreen").style.display="flex";
  }else{
    alert("wrong password");
  }
}

/* MODAL */
let noCount = 0;

function openConfirm(){
  document.getElementById("modal").style.display="flex";
}

function yesOpen(){
  document.getElementById("modal").style.display="none";

  const letter=document.getElementById("letter");
  letter.style.display="block";

  setTimeout(()=>{
    letter.classList.add("show");
  },50);
}

function noOpen(){
  const text=document.getElementById("noText");
  const noBtn=document.querySelector(".no");
  const yesBtn=document.querySelector(".yes");

  noCount++;

  if(noCount === 1){
    text.innerHTML="Are you sure? 😶";
  }

  if(noCount === 2){
    text.innerHTML="Really? Think again...";
  }

  if(noCount >= 3){
    text.innerHTML="Okay... but you're still going to open it 😏";

    yesBtn.style.transform="scale(1.2)";
    yesBtn.style.boxShadow="0 0 15px #c9a38b";
  }

  noBtn.style.left=(Math.random()*20-10)+"px";
  noBtn.style.top=(Math.random()*10-5)+"px";

  setTimeout(()=>{
    text.innerHTML="Try again.";
  },1500);
}

</script>

</body>
</html>
